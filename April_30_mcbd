    "import numpy as np\n",
    "import pandas as pd\n",
    "from scipy import stats\n",
    "import statsmodels.api as sm\n",
    "\n",
    "np.random.seed(42)\n",
    "\n",
    "\n",
    "n_A = 20\n",
    "n_B = 20\n",
    "\n",
    "group_A = np.random.normal(loc=10, scale=2, size=n_A)\n",
    "group_B = np.random.normal(loc=13, scale=2, size=n_B)\n",
    "\n",
    "y = np.concatenate([group_A, group_B])\n",
    "G = np.concatenate([np.zeros(n_A), np.ones(n_B)])\n",
    "\n",
    "X = sm.add_constant(G)\n",
    "\n",
    "\n",
    "student_t, student_p = stats.ttest_ind(group_B, group_A, equal_var=True)\n",
    "\n",
    "model_raw = sm.OLS(y, X).fit()\n",
    "\n",
    "reg_t = model_raw.tvalues[1]\n",
    "reg_p = model_raw.pvalues[1]\n",
    "beta1_raw = model_raw.params[1]\n",
    "\n",
    "\n",
    "wald_stat_manual = reg_t ** 2\n",
    "wald_p_manual = stats.chi2.sf(wald_stat_manual, df=1)\n",
    "\n",
    "wald_sm = model_raw.wald_test(\"x1 = 0\", use_f=False, scalar=True)\n",
    "wald_stat_sm = float(wald_sm.statistic)\n",
    "wald_p_sm = float(wald_sm.pvalue)\n",
    "\n",
    "\n",
    "ranks = stats.rankdata(y)\n",
    "\n",
    "model_rank = sm.OLS(ranks, X).fit()\n",
    "\n",
    "rank_beta1 = model_rank.params[1]\n",
    "rank_t = model_rank.tvalues[1]\n",
    "rank_p = model_rank.pvalues[1]\n",
    "\n",
    "mw_stat, mw_p = stats.mannwhitneyu(group_B, group_A, alternative=\"two-sided\")\n",
    "\n",
    "\n",
    "n_pairs = 20\n",
    "\n",
    "before = np.random.normal(loc=10, scale=2, size=n_pairs)\n",
    "after = before + np.random.normal(loc=1.2, scale=1.2, size=n_pairs)\n",
    "\n",
    "d = after - before\n",
    "\n",
    "wilcoxon_stat, wilcoxon_p = stats.wilcoxon(d, alternative=\"two-sided\")\n",
    "\n",
    "# Signed ranks\n",
    "abs_d = np.abs(d)\n",
    "\n",
    "# Remove zero differences, because Wilcoxon ignores zero differences\n",
    "nonzero = abs_d > 0\n",
    "d_nonzero = d[nonzero]\n",
    "abs_d_nonzero = abs_d[nonzero]\n",
    "\n",
    "signed_ranks = np.sign(d_nonzero) * stats.rankdata(abs_d_nonzero)\n",
    "\n",
    "# Intercept-only regression on signed ranks\n",
    "X_intercept = np.ones((len(signed_ranks), 1))\n",
    "model_signed_rank = sm.OLS(signed_ranks, X_intercept).fit()\n",
    "\n",
    "signed_rank_intercept = model_signed_rank.params[0]\n",
    "signed_rank_t = model_signed_rank.tvalues[0]\n",
    "signed_rank_p = model_signed_rank.pvalues[0]\n",
    "\n",
    "\n",
