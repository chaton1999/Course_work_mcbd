    "## General case: two groups with two slopes\n",
    "\n",
    "import matplotlib.pyplot as plt\n",
    "import statsmodels.api as sm\n",
    "\n",
    "# -----------------------------\n",
    "# Generate example data\n",
    "# -----------------------------\n",
    "np.random.seed(42)\n",
    "\n",
    "n = 30\n",
    "\n",
    "# x = concentration\n",
    "x_A = np.linspace(0, 10, n)\n",
    "x_B = np.linspace(0, 10, n)\n",
    "\n",
    "# Group indicator\n",
    "# Group A = 0\n",
    "# Group B = 1\n",
    "G_A = np.zeros(n)\n",
    "G_B = np.ones(n)\n",
    "\n",
    "# -----------------------------\n",
    "# True models\n",
    "# -----------------------------\n",
    "# Group A:\n",
    "# y = beta0_A + beta1_A*x + error\n",
    "\n",
    "beta0_A = 2.0\n",
    "beta1_A = 1.2\n",
    "\n",
    "# Group B:\n",
    "# y = beta0_B + beta1_B*x + error\n",
    "\n",
    "beta0_B = 4.0\n",
    "beta1_B = 2.0\n",
    "\n",
    "error_A = np.random.normal(loc=0, scale=2.0, size=n)\n",
    "error_B = np.random.normal(loc=0, scale=2.0, size=n)\n",
    "\n",
    "y_A = beta0_A + beta1_A * x_A + error_A\n",
    "y_B = beta0_B + beta1_B * x_B + error_B\n",
    "\n",
    "# -----------------------------\n",
    "# Combine both groups\n",
    "# -----------------------------\n",
    "x = np.concatenate([x_A, x_B])\n",
    "G = np.concatenate([G_A, G_B])\n",
    "y = np.concatenate([y_A, y_B])\n",
    "\n",
    "# Interaction term\n",
    "xG = x * G\n",
    "\n",
    "# -----------------------------\n",
    "# Fit linear model\n",
    "# -----------------------------\n",
    "# Model:\n",
    "#\n",
    "# y = beta0 + beta1*x + beta2*G + beta3*xG + error\n",
    "#\n",
    "# where:\n",
    "# beta0 = intercept of Group A\n",
    "# beta1 = slope of Group A\n",
    "# beta2 = difference in intercept between Group B and Group A\n",
    "# beta3 = difference in slope between Group B and Group A\n",
    "\n",
    "X = np.column_stack([x, G, xG])\n",
    "X = sm.add_constant(X, has_constant=\"add\")\n",
    "\n",
    "model = sm.OLS(y, X).fit()\n",
    "\n",
    "print(model.summary())\n",
    "\n",
    "# -----------------------------\n",
    "# Extract fitted parameters\n",
    "# -----------------------------\n",
    "beta0_hat = model.params[0]\n",
    "beta1_hat = model.params[1]\n",
    "beta2_hat = model.params[2]\n",
    "beta3_hat = model.params[3]\n",
    "\n",
    "print(\"\\nFitted model interpretation:\")\n",
    "print(f\"Group A intercept = beta0 = {beta0_hat:.3f}\")\n",
    "print(f\"Group A slope     = beta1 = {beta1_hat:.3f}\")\n",
    "print(f\"Group B intercept = beta0 + beta2 = {beta0_hat + beta2_hat:.3f}\")\n",
    "print(f\"Group B slope     = beta1 + beta3 = {beta1_hat + beta3_hat:.3f}\")\n",
    "\n",
    "print(\"\\nHypothesis test for slope difference:\")\n",
    "print(\"H0: beta3 = 0\")\n",
    "print(f\"Estimated beta3 = {beta3_hat:.3f}\")\n",
    "print(f\"p-value for beta3 = {model.pvalues[3]:.5f}\")\n",
    "\n",
    "# -----------------------------\n",
    "# Predictions for each group\n",
    "# -----------------------------\n",
    "x_line = np.linspace(0, 10, 100)\n",
    "\n",
    "# Group A prediction, G = 0\n",
    "G_line_A = np.zeros_like(x_line)\n",
    "xG_line_A = x_line * G_line_A\n",
    "\n",
    "X_A_pred = np.column_stack([x_line, G_line_A, xG_line_A])\n",
    "X_A_pred = sm.add_constant(X_A_pred, has_constant=\"add\")\n",
    "\n",
    "y_A_pred = model.predict(X_A_pred)\n",
    "\n",
    "# Group B prediction, G = 1\n",
    "G_line_B = np.ones_like(x_line)\n",
    "xG_line_B = x_line * G_line_B\n",
    "\n",
    "X_B_pred = np.column_stack([x_line, G_line_B, xG_line_B])\n",
    "X_B_pred = sm.add_constant(X_B_pred, has_constant=\"add\")\n",
    "\n",
    "y_B_pred = model.predict(X_B_pred)\n",
    "\n",
    "# Check dimensions\n",
    "print(\"\\nShape check:\")\n",
    "print(\"X_A_pred shape:\", X_A_pred.shape)\n",
    "print(\"X_B_pred shape:\", X_B_pred.shape)\n",
    "print(\"model parameter shape:\", model.params.shape)\n",
    "\n",
    "# -----------------------------\n",
    "# Plot data and fitted lines\n",
    "# -----------------------------\n",
    "plt.figure(figsize=(8, 6))\n",
    "\n",
    "plt.scatter(x_A, y_A, s=80, label=\"Group A observed\")\n",
    "plt.scatter(x_B, y_B, s=80, label=\"Group B observed\")\n",
    "\n",
    "plt.plot(x_line, y_A_pred, linewidth=3, label=\"Group A fitted line\")\n",
    "plt.plot(x_line, y_B_pred, linewidth=3, label=\"Group B fitted line\")\n",
    "\n",
    "plt.xlabel(\"Concentration, x\")\n",
    "plt.ylabel(\"Product formed, y\")\n",
    "plt.title(\"General Linear Model\")\n",
    "plt.legend()\n",
    "\n",
    "plt.tight_layout()\n",
    "plt.show()"
   ]
