    "        student_p,\n",
    "        reg_p,\n",
    "        wald_p_manual,\n",
    "        mw_p,\n",
    "        rank_p,\n",
    "        wilcoxon_p,\n",
    "        signed_rank_p\n",
    "    ]\n",
    "})\n",
