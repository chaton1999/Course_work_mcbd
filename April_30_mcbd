    "print(\"Classical two-sample Student's t-test\")\n",
    "print(\"t-statistic:\", student_t)\n",
    "print(\"p-value:\", student_p)\n",
    "\n",
    "\n",
    "y = np.concatenate([group_A, group_B])\n",
    "\n",
    "# For the cleanest interpretation:\n",
    "# G = 0 for group A\n",
    "# G = 1 for group B\n",
    "G = np.concatenate([\n",
